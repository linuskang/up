{
    "$schema": "https://turbo.build/schema.json",
    "ui": "tui",
    "tasks": {
        "build": {
            "dependsOn": ["^build"],
            "inputs": ["$TURBO_DEFAULT$", ".env*"],
            "outputs": [".next/**", "!.next/cache/**", "dist/**"]
        },
        "lint": {},
        "typecheck": {
            "dependsOn": ["^build"]
        },
        "format": {},
        "dev": {
            "cache": false,
            "persistent": true
        }
    }
}
